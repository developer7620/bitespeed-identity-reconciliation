# PostgreSQL connection string
# Local:  postgresql://postgres:password@localhost:5432/bitespeed_identity
# Neon:   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/bitespeed_identity?schema=public"

# Server port (defaults to 3000)
PORT=3000

# Environment: development | production | test
NODE_ENV=development

# Log level: error | warn | info | debug  (defaults to info)
LOG_LEVEL=info
